{
  "expo": {
    "name": "Gestus",
    "slug": "Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoP.png", 
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/LogoP.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1e1e"
    },
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.samelafarias.gestus"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoP.png",
        "backgroundColor": "#1e1e1e"
      },
      "package": "com.samelafarias.gestus",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/LogoP.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "747a9267-3984-4bf5-8af0-bff947ba6014"
      }
    },
    "owner": "samelafarias",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/747a9267-3984-4bf5-8af0-bff947ba6014"
    }
  }
}